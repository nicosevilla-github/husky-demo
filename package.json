{
  "name": "husky-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .js,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.ts,.vue --fix",
    "stylelint": "stylelint \"src/**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"src/**/*.{css,scss,vue}\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "format:styles": "prettier --write \"src/**/*.{css,scss}\"",
    "format:file": "prettier --write",
    "test": "echo \"No tests configured yet\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.vue": [
      "eslint --fix",
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{css,scss}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,html}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "eslint": "^10.0.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "postcss-html": "^1.8.0",
    "prettier": "^3.5.2",
    "sass": "^1.85.1",
    "stylelint": "^16.15.0",
    "stylelint-config-standard-scss": "^14.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vue-eslint-parser": "^10.4.0"
  }
}
